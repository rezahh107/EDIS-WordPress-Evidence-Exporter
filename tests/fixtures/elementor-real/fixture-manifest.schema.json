{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edis.local/schemas/elementor-real-fixture-manifest-1.json",
  "title": "EDIS controlled real Elementor fixture manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixture_id", "verification_state", "environment", "files"],
  "properties": {
    "schema_version": {"const": "EDIS-ELEMENTOR-REAL-FIXTURE-1"},
    "fixture_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,80}$"},
    "verification_state": {"const": "verified_by_real_fixture"},
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wordpress_version", "elementor_version", "php_version", "captured_at_utc"],
      "properties": {
        "wordpress_version": {"type": "string"},
        "elementor_version": {"type": "string"},
        "php_version": {"type": "string"},
        "captured_at_utc": {"type": "string", "format": "date-time"}
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "pattern": "^[^\\\\/](?:[^\\\\]*[^\\\\/])?$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
