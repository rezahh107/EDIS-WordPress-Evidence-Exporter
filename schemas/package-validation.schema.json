{
  "$id": "urn:edis:schema:wordpress:package-validation:1.3.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "analysis_readiness": {
      "enum": [
        "PASS",
        "PARTIAL",
        "INSUFFICIENT",
        "FAIL",
        "NOT_APPLICABLE"
      ]
    },
    "checks": {
      "additionalProperties": {
        "type": "boolean"
      },
      "type": "object"
    },
    "contract_validation": {
      "enum": [
        "PASS",
        "FAIL",
        "NOT_RUN"
      ]
    },
    "diagnostics": {
      "type": "array"
    },
    "instance_hash_failure_paths": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "package_integrity": {
      "enum": [
        "PASS",
        "FAIL",
        "NOT_RUN"
      ]
    },
    "schema_failure_details": {
      "additionalProperties": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "keyword": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "path",
            "keyword",
            "message"
          ],
          "type": "object"
        },
        "type": "array"
      },
      "type": "object"
    },
    "semantic_hash_failure_paths": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "source_export_root_sha256": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "state": {
      "enum": [
        "PASS",
        "FAIL",
        "NOT_RUN"
      ]
    }
  },
  "required": [
    "state",
    "package_integrity",
    "contract_validation",
    "analysis_readiness",
    "checks",
    "diagnostics",
    "source_export_root_sha256",
    "semantic_hash_failure_paths",
    "schema_failure_details",
    "instance_hash_failure_paths"
  ],
  "type": "object"
}
